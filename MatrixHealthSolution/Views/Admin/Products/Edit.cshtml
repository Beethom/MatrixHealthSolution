@model MatrixHealthSolution.Models.Product
@{
    ViewData["Title"] = "Edit Product";
}

<section class="device-section">
    <div class="container">
        <h2 class="section-title">Edit Product</h2>

        <form asp-area="Admin" asp-controller="Products" asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImagePath" />

            <div class="form-group">
                <label>Current Image</label><br />
                <img
                    src="@(string.IsNullOrWhiteSpace(Model.ImagePath) ? "/images/placeholder.png" : Model.ImagePath)"
                    alt="@Model.Name"
                    style="width:260px; height:160px; object-fit:cover; border-radius:12px;" />
            </div>

            <div class="form-group">
                <label>Replace Image</label>
                <input type="file" name="imageFile" accept="image/*" />
            </div>

            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" />
                <span asp-validation-for="Name"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description"></textarea>
            </div>

            <div class="form-group">
                <label asp-for="Price"></label>
                <input asp-for="Price" />
                <span asp-validation-for="Price"></span>
            </div>

            <div class="form-group">
                <label asp-for="Stock"></label>
                <input asp-for="Stock" />
            </div>

            <div class="form-group">
                <label asp-for="IsActive"></label>
                <select asp-for="IsActive">
                    <option value="true">True</option>
                    <option value="false">False</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary">Update</button>
            <a class="btn btn-secondary" asp-area="Admin" asp-controller="Products" asp-action="Index">Cancel</a>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
