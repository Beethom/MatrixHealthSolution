@model MatrixHealthSolution.Models.GiftCard
@{ ViewData["Title"] = "Edit Gift Card"; }
<section class="services"><div class="container">
  <h2 class="section-title">Edit Gift Card</h2>
  <form asp-area="Admin" asp-controller="GiftCards" asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
    <div class="form-group"><label asp-for="Code"></label><input asp-for="Code" /><span asp-validation-for="Code" class="text-danger"></span></div>
    <div class="form-group"><label asp-for="Value"></label><input asp-for="Value" /><span asp-validation-for="Value" class="text-danger"></span></div>
    <div class="form-group"><label asp-for="ExpiryDate"></label><input asp-for="ExpiryDate" type="date" /></div>
    <div class="form-group"><label asp-for="IsActive"></label><input asp-for="IsActive" type="checkbox" /></div>
    <button class="btn btn-primary" type="submit">Update</button>
    <a class="btn btn-secondary" asp-area="Admin" asp-controller="GiftCards" asp-action="Index">Cancel</a>
  </form>
</div></section>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
