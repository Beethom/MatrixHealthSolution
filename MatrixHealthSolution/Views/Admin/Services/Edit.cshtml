@{
    ViewData["Title"] = "Edit Service";
}
@model MatrixHealthSolution.Models.Service

@{
    ViewData["Title"] = "Edit Service";
}

<section class="container" style="padding:3rem 0;">
    <h2 class="section-title">Edit Service</h2>

    <form asp-action="Edit" method="post" style="max-width:600px;margin:0 auto;">
        @Html.AntiForgeryToken()

        <!-- VERY IMPORTANT: Id must be posted -->
        <input type="hidden" asp-for="Id" />

        <div class="form-group mb-3">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Price"></label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="IsActive"></label>
            <input asp-for="IsActive" />
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
