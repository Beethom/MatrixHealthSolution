@model MatrixHealthSolution.Models.Employee
@{ ViewData["Title"] = "Add Employee"; }
<section class="services"><div class="container">
  <h2 class="section-title">Add Employee</h2>
  <form asp-area="Admin" asp-controller="Employees" asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
    <div class="form-group"><label asp-for="FullName"></label><input asp-for="FullName" /><span asp-validation-for="FullName" class="text-danger"></span></div>
    <div class="form-group"><label asp-for="Email"></label><input asp-for="Email" /><span asp-validation-for="Email" class="text-danger"></span></div>
    <div class="form-group"><label asp-for="Position"></label><input asp-for="Position" /><span asp-validation-for="Position" class="text-danger"></span></div>
    <div class="form-group"><label asp-for="IsActive"></label><input asp-for="IsActive" type="checkbox" /></div>
    <button class="btn btn-primary" type="submit">Save</button>
    <a class="btn btn-secondary" asp-area="Admin" asp-controller="Employees" asp-action="Index">Cancel</a>
  </form>
</div></section>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
