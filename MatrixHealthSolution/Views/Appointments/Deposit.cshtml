@model MatrixHealthSolution.Models.Appointment
@{
    ViewData["Title"] = "Pay Deposit";
}

<section class="services">
    <div class="container">
        <h2 class="section-title">Confirm Your Deposit</h2>

        <div class="service-card" style="max-width:800px;margin:0 auto;">
            <h3>@Model.Service?.Name</h3>
            <p><strong>Date:</strong> @Model.ScheduledAt.ToString("MMMM dd, yyyy")</p>
            <p><strong>Time:</strong> @Model.ScheduledAt.ToString("hh:mm tt")</p>

            <hr class="mb-3 mt-3"/>

            <p><strong>Name:</strong> @Model.FirstName @Model.LastName</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Phone:</strong> @Model.Phone</p>
            <p><strong>Preferred Contact:</strong> @Model.PreferredContact</p>

            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <p><strong>Notes:</strong> @Model.Notes</p>
            }

            <hr class="mb-3 mt-3"/>

            <p><strong>Deposit Amount:</strong> $@Model.DepositAmount</p>
            <p><strong>Status:</strong> @Model.Status</p>

            @if (User.IsInRole("Admin"))
            {
                <form asp-action="MarkDepositPaid" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-warning">Mark Deposit Paid (Admin)</button>
                </form>
            }
            else
            {
                <div class="alert alert-info mt-3">
                    Your appointment is booked. Our team will follow up to collect the deposit of <strong>$@Model.DepositAmount</strong> before your visit.
                </div>
            }
        </div>
    </div>
</section>
