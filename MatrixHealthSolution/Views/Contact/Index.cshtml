@model MatrixHealthSolution.Models.ViewModels.ContactVM

@{
    ViewData["Title"] = "Contact Us";
}

<section class="services">
    <div class="container">
        <h2 class="section-title">Contact Us</h2>

        @if (TempData["Success"] != null)
        {
            <div style="background:#e8f5e8; border:1px solid #81c784; padding:12px; border-radius:12px; margin-bottom:16px;">
                @TempData["Success"]
            </div>
        }

        <form method="post" class="service-card" style="max-width:800px; margin:0 auto;">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" style="color:#b00020;"></div>

            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" />
                <span asp-validation-for="Name"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" />
                <span asp-validation-for="Email"></span>
            </div>

            <div class="form-group">
                <label asp-for="Subject"></label>
                <input asp-for="Subject" />
                <span asp-validation-for="Subject"></span>
            </div>

            <div class="form-group">
                <label asp-for="Message"></label>
                <textarea asp-for="Message" rows="5"></textarea>
                <span asp-validation-for="Message"></span>
            </div>

            <div class="hero-buttons" style="margin-top:16px;">
                <button class="btn btn-primary" type="submit">Send Message</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
